{
  "name": "bomr",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "build:ios:dev": "npx eas-cli build --profile development --platform ios",
    "build:android:dev": "npx eas-cli build --profile development --platform android",
    "lint": "expo lint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run test && npm run typecheck",
    "smoke": "npm run build",
    "smoke:web": "node ./scripts/web-smoke.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.8",
    "expo": "^55",
    "expo-asset": "~55.0.8",
    "expo-audio": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.13",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-keep-awake": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-speech": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~55.0.0",
    "playwright": "^1.58.2",
    "typescript": "~5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "private": true
}
